{
  "name": "@senti-pocket/pocket-gateway",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Senti Pocket gateway: checkpoint extract -> grounded summarizer -> PocketBundle builder -> receipts. Owner: claude-pocket-relay.",
  "engines": {
    "node": "^20.0.0 || ^22.0.0"
  },
  "bin": {
    "pocket-gateway": "src/cli.ts"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/cli.ts",
    "smoke": "node --experimental-strip-types src/cli.ts fixtures/raw_export.sample.json",
    "test": "node --experimental-strip-types --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
